<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record id="badge_carbon_saver" model="ecosphere.badge">
        <field name="name">Carbon Saver</field>
        <field name="description">
            Reduced carbon emissions significantly
        </field>
        <field name="unlock_rule">
            Reduce 500 kg CO2
        </field>
    </record>


    <record id="badge_green_employee" model="ecosphere.badge">
        <field name="name">Green Employee</field>
        <field name="description">
            Participated in sustainability activities
        </field>
        <field name="unlock_rule">
            Complete 10 activities
        </field>
    </record>

</odoo>