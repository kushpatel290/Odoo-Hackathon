<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 1. ACTION: Link to the Compliance Issue model -->
    <record id="action_compliance_issue" model="ir.actions.act_window">
        <field name="name">Compliance Issues</field>
        <field name="res_model">ecosphere.compliance.issue</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- 2. MENU ITEM: Place it under the 'Governance' top menu -->
    <menuitem id="menu_compliance_issue" 
              name="Compliance Issues" 
              parent="menu_governance" 
              action="action_compliance_issue" 
              sequence="10"/>

    <!-- 3. TREE VIEW -->
    <record id="view_compliance_issue_tree" model="ir.ui.view">
        <field name="name">ecosphere.compliance.issue.tree</field>
        <field name="res_model">ecosphere.compliance.issue</field>
        <field name="arch" type="xml">
            <tree string="Compliance Issues" decoration-danger="severity=='critical'" decoration-warning="severity=='high'">
                <field name="name"/>
                <field name="severity"/>
                <field name="owner_id"/>
                <field name="due_date"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- 4. FORM VIEW -->
    <record id="view_compliance_issue_form" model="ir.ui.view">
        <field name="name">ecosphere.compliance.issue.form</field>
        <field name="res_model">ecosphere.compliance.issue</field>
        <field name="arch" type="xml">
            <form string="Compliance Issue">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="open,resolved,closed"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="severity"/>
                        <field name="owner_id"/>
                        <field name="due_date"/>
                    </group>
                </sheet>
                <!-- Adding the chatter/notification system -->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
</odoo>