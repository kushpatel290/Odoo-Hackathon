<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_carbon_transaction" model="ir.actions.act_window">
        <field name="name">Carbon Transactions</field>
        <field name="res_model">ecosphere.carbon.transaction</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_carbon_tx" 
              name="Carbon Tracker" 
              parent="menu_environmental" 
              action="action_carbon_transaction" 
              sequence="10"/>

    <record id="view_carbon_transaction_tree" model="ir.ui.view">
        <field name="name">ecosphere.carbon.transaction.tree</field>
        <field name="res_model">ecosphere.carbon.transaction</field>
        <field name="arch" type="xml">
            <tree string="Carbon Transactions">
                <field name="name"/>
                <field name="department_id"/>
                <field name="date"/>
                <field name="quantity"/>
                <field name="calculated_carbon"/>
            </tree>
        </field>
    </record>

    <record id="view_carbon_transaction_form" model="ir.ui.view">
        <field name="name">ecosphere.carbon.transaction.form</field>
        <field name="res_model">ecosphere.carbon.transaction</field>
        <field name="arch" type="xml">
            <form string="Carbon Transaction">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. TX-2026-001"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="department_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="emission_factor_id"/>
                            <field name="quantity"/>
                            <field name="calculated_carbon" readonly="1" force_save="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>