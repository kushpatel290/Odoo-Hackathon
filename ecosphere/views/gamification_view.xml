<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_badge" model="ir.actions.act_window">
        <field name="name">Badges</field>
        <field name="res_model">ecosphere.badge</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_badge"
              name="Badges"
              parent="menu_gamification"
              action="action_badge"/>

    <record id="view_badge_tree" model="ir.ui.view">
        <field name="name">ecosphere.badge.tree</field>
        <field name="model">ecosphere.badge</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="unlock_rule"/>
            </tree>
        </field>
    </record>

    <record id="view_badge_form" model="ir.ui.view">
        <field name="name">ecosphere.badge.form</field>
        <field name="model">ecosphere.badge</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="unlock_rule"/>
                        <field name="icon"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_reward" model="ir.actions.act_window">
        <field name="name">Rewards</field>
        <field name="res_model">ecosphere.reward</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_reward"
              name="Rewards"
              parent="menu_gamification"
              action="action_reward"/>

</odoo>